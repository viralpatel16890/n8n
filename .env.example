# ============================================================
# n8n GoDaddy PaaS Environment Variables
# Set these in GoDaddy dashboard → App Settings → Environment
# DO NOT upload this file — set each var in the dashboard
# ============================================================

# --- Security (REQUIRED) ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-strong-password-here
N8N_ENCRYPTION_KEY=your-random-32-char-secret-here

# --- URLs (update with your GoDaddy app URL) ---
N8N_HOST=your-app-name.on-godaddy.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-app-name.on-godaddy.com/

# --- Timezone ---
GENERIC_TIMEZONE=Asia/Kolkata

# --- Database (SQLite default — use Postgres for persistence) ---
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=your-db-host
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n
# DB_POSTGRESDB_PASSWORD=your-db-password

# --- Misc ---
N8N_METRICS=false
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
